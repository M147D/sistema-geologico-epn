# Desarrollo local: ruta relativa — Vite (vite.config.js) la reenvía a
# http://localhost:5095 mediante su proxy de /api. Evita problemas de CORS
# y funciona igual si abres la app desde otro dispositivo en la LAN.
VITE_API_URL=/api

# Producción / despliegue en dominios separados: no hay Vite corriendo, así
# que no existe proxy. Usa la URL absoluta del Back-End desplegado y
# asegúrate de que esté en la lista de orígenes permitidos por CORS
# (ver Program.cs → AddCors).
# VITE_API_URL=https://api.tu-dominio.com/api

# Activar datos locales para pruebas sin Backend activo (true | false)
VITE_USE_STUBS=false
